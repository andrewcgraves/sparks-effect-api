PORT=8080
STADIA_API_KEY=

# Set LOG_LEVEL=debug (or VERBOSE=true) to enable verbose request/response logging.
# Logs Stadia endpoint name, HTTP status, latency, and error body snippets.
# The Stadia API key is never logged.
# Leave unset (or set to any other value) for quiet production output.
LOG_LEVEL=

# Set ALLOW_LOCALHOST_CORS=true to allow CORS requests from localhost origins
# (e.g. http://localhost:5173, http://127.0.0.1:4173) during local SPA testing.
# Off by default — do not enable in production.
ALLOW_LOCALHOST_CORS=
